generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String             @id @default(cuid())
  userName      String
  email         String             @unique
  notification  Notification[]
  notifications notificationRead[]
}

model Department {
  id              String           @id @default(cuid())
  name            String           @unique
  teacherId       String?
  announcements   Announcement[]
  supervisor      Teacher?         @relation("DepartmentSupervisor", fields: [teacherId], references: [id])
  events          Event[]
  examDepartments ExamDepartment[]
  students        Student[]
  subjects        Subject[]        @relation("DepartmentToSubject")

  @@index([teacherId], map: "Department_teacherId_fkey")
}

model Grade {
  id       String    @id @default(cuid())
  name     String    @unique
  subjects Subject[]
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  gradeId     String?
  assignments Assignment[]
  attendance  Attendance[]
  exams       Exam[]
  results     Result[]
  grade       Grade?       @relation(fields: [gradeId], references: [id])
  timetables  Timetable[]
  classrooms  Classroom[]  @relation("ClassroomToSubject")
  department  Department[] @relation("DepartmentToSubject")
  students    Student[]    @relation("StudentToSubject")
  teachers    Teacher[]    @relation("SubjectToTeacher")

  @@index([gradeId], map: "Subject_gradeId_fkey")
}

model Student {
  id           String             @id @default(cuid())
  username     String             @unique
  email        String             @unique
  age          Int
  address      String
  phoneNumber  String             @unique
  firstName    String
  lastName     String
  image        String?
  sex          Usersex
  createdAt    DateTime           @default(now())
  parentId     String?
  departmentId String
  gradeId      String?
  levelId      Int
  matricule    String?            @unique
  DateOfBirth  DateTime?
  attendance   Attendance[]
  fees         Fee[]
  results      Result[]
  department   Department         @relation(fields: [departmentId], references: [id])
  level        Level              @relation(fields: [levelId], references: [id])
  parent       Parent?            @relation(fields: [parentId], references: [id])
  readReceipts notificationRead[]
  courses      Subject[]          @relation("StudentToSubject")

  @@index([departmentId], map: "Student_departmentId_fkey")
  @@index([levelId], map: "Student_levelId_fkey")
  @@index([parentId], map: "Student_parentId_fkey")
}

model Level {
  id        Int       @id @default(autoincrement())
  LevelName String    @unique
  exam      Exam[]
  student   Student[]
}

model Teacher {
  id            String             @id @default(cuid())
  username      String             @unique
  email         String             @unique
  address       String
  bloodGroup    String?
  phoneNumber   String             @unique
  firstName     String
  lastName      String
  sex           Usersex
  image         String?
  DateOfBirth   DateTime?
  teachersId    String?
  department    Department[]       @relation("DepartmentSupervisor")
  notifications Notification[]
  readReceipts  notificationRead[]
  courses       Subject[]          @relation("SubjectToTeacher")
}

model Parent {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  sex         Usersex
  address     String
  phoneNumber String    @unique
  firstName   String
  lastName    String
  students    Student[]
}

model Classroom {
  id       String    @id @default(cuid())
  name     String    @unique
  courseId Int
  exams    Exam[]
  course   Subject[] @relation("ClassroomToSubject")
}

model Event {
  id           String      @id @default(cuid())
  name         String      @unique
  startDate    DateTime
  endDate      DateTime
  description  String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([departmentId], map: "Event_departmentId_fkey")
}

model Exam {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  title           String
  startDate       DateTime
  endDate         DateTime
  courseId        Int
  ClassRoomId     String
  schoolYear      String
  levelId         Int
  Invigilator     String?
  classroom       Classroom        @relation(fields: [ClassRoomId], references: [id])
  course          Subject          @relation(fields: [courseId], references: [id])
  level           Level            @relation(fields: [levelId], references: [id])
  examDepartments ExamDepartment[]
  results         Result[]

  @@index([ClassRoomId], map: "Exam_ClassRoomId_fkey")
  @@index([courseId], map: "Exam_courseId_fkey")
  @@index([levelId], map: "Exam_levelId_fkey")
}

model ExamDepartment {
  examId       Int
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@id([examId, departmentId])
  @@index([departmentId], map: "ExamDepartment_departmentId_fkey")
}

model Attendance {
  id        Int      @id @default(autoincrement())
  present   Boolean
  date      DateTime
  status    String
  courseId  Int
  studentId String
  course    Subject  @relation(fields: [courseId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([courseId], map: "Attendance_courseId_fkey")
  @@index([studentId], map: "Attendance_studentId_fkey")
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime
  courseId  Int
  course    Subject  @relation(fields: [courseId], references: [id])

  @@index([courseId], map: "Assignment_courseId_fkey")
}

model Result {
  id        Int      @id @default(autoincrement())
  CA        Int
  Exam      Int
  total     Int
  date      DateTime
  studentId String
  courseId  Int
  examId    Int?
  grand     String
  course    Subject  @relation(fields: [courseId], references: [id])
  exam      Exam?    @relation(fields: [examId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, courseId])
  @@index([courseId], map: "Result_courseId_fkey")
  @@index([examId], map: "Result_examId_fkey")
}

model Timetable {
  id        String   @id @default(cuid())
  courseId  Int
  startTime DateTime
  endTime   DateTime
  day       String
  course    Subject  @relation(fields: [courseId], references: [id])

  @@index([courseId], map: "Timetable_courseId_fkey")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  date       DateTime
}

model Fee {
  id        String   @id @default(cuid())
  studentId String
  amount    Float
  dueDate   DateTime
  status    String
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId], map: "Fee_studentId_fkey")
}

model Announcement {
  id               String             @id @default(cuid())
  title            String
  message          String             @db.Text
  date             DateTime           @default(now())
  departmentId     String?
  department       Department?        @relation(fields: [departmentId], references: [id])
  notificationRead notificationRead[]

  @@index([departmentId], map: "Announcement_departmentId_fkey")
}

model Notification {
  id               String             @id @default(cuid())
  title            String
  message          String
  adminId          String?
  createdAt        DateTime           @default(now())
  teacherId        String?
  admin            Admin?             @relation(fields: [adminId], references: [id], onDelete: Cascade)
  teacher          Teacher?           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  notificationRead notificationRead[]

  @@index([adminId], map: "Notification_adminId_fkey")
  @@index([teacherId], map: "Notification_teacherId_fkey")
}

model notificationRead {
  id             String        @id @default(cuid())
  notificationId String
  read           Boolean       @default(false)
  readAt         DateTime?
  studentId      String?
  teacherId      String?
  adminId        String?
  announcementId String?
  admin          Admin?        @relation(fields: [adminId], references: [id])
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  notification   Notification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  student        Student?      @relation(fields: [studentId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([adminId])
  @@index([notificationId])
  @@index([announcementId])
}

enum Usersex {
  Male
  Female
}
